# Database
DATABASE_URL=sqlite:panel.db

# Server
PANEL_PORT=3030
PANEL_HOST=0.0.0.0
PANEL_SECRET_KEY=your-secret-key-here-change-in-production

# OpenLiteSpeed
OLS_CONFIG_DIR=/usr/local/lsws/conf
OLS_VHOST_DIR=/usr/local/lsws/conf/vhosts
OLS_LSPHP_BIN=/usr/local/lsws/lsphp83/bin/lsphp

# Let's Encrypt
CERTBOT_PATH=/usr/bin/certbot
LE_WEBROOT=/usr/local/lsws/html

# Logging
RUST_LOG=info,panel=debug
