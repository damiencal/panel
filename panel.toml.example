[server]
host = "0.0.0.0"
port = 3030
# IMPORTANT: Replace this with a strong random key before any deployment.
# Generate one with: openssl rand -base64 32
# The key MUST be at least 32 characters. The install.sh script sets this automatically.
secret_key = "REPLACE_ME_WITH_OPENSSL_RAND_BASE64_32_OUTPUT_HERE_DEV"

[database]
url = "sqlite:panel.db"

[openlitespeed]
config_dir = "/usr/local/lsws/conf"
vhost_dir = "/usr/local/lsws/conf/vhosts"
lsphp_bin = "/usr/local/lsws/lsphp83/bin/lsphp"

[certbot]
path = "/usr/bin/certbot"
webroot = "/usr/local/lsws/html"

[phpmyadmin]
enabled = true
install_path = "/usr/share/phpmyadmin"
url_base_path = "/phpmyadmin"

[cloudflare]
api_token = ""

[mariadb]
bind_address = "127.0.0.1"
port = 3306
max_connections = 100

[postfix]
hostname = "mail.localhost"
virtual_mailbox_base = "/var/mail/vhosts"

[dovecot]
mail_location = "maildir:/var/mail/vhosts/%d/%n"
users_file = "/etc/dovecot/users"

[ftp]
passive_port_min = 30000
passive_port_max = 50000
max_clients = 50
tls_required = true

[audit]
# Number of days to retain audit log entries.
# 30 is sufficient for most deployments; compliance environments (PCI-DSS,
# HIPAA) typically require 90–365 days.
log_retention_days = 30

[request_security]
# Optional allowlist for protected panel requests (`/_dioxus/*` and `/api/*`).
# Leave empty to allow any client IP, or use exact IPs / CIDR ranges.
allowed_ips = []
# Global per-IP throttle for protected requests. Set to 0 to disable.
rate_limit_requests = 600
rate_limit_window_secs = 60
